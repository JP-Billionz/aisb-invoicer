# Postgres (Render Postgres connection string)
DATABASE_URL="postgresql://user:password@host:5432/aisb_invoicer"

# NextAuth
# Set NEXTAUTH_URL to https://invoices.aisolutionsbb.com in production
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Email magic-link (live send wired in Phase 1B — leave blank for Phase 1A)
EMAIL_FROM="AISB Invoicer <noreply@aisolutionsbb.com>"
SENDGRID_API_KEY=""

# Stripe (Phase 1B)
# Secret key (sk_live_... in prod, sk_test_... in dev): Dashboard → Developers → API keys
STRIPE_SECRET_KEY=""
# Publishable key — not yet referenced server-side, future-proofing for Elements
STRIPE_PUBLISHABLE_KEY=""
# Webhook signing secret (whsec_...): Dashboard → Webhooks → endpoint → Reveal
STRIPE_WEBHOOK_SECRET=""
# Recurring price IDs (price_...): Dashboard → Products → each product → Pricing
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_GROWTH=""
STRIPE_PRICE_PRO=""

# Monitoring
SENTRY_DSN=""
PLAUSIBLE_DOMAIN=""
